<div class="auth-split-wrapper">
  
  <!-- Left Side: Brand Showcase (Hidden on Mobile) -->
  <div class="auth-brand-side">
    <div class="brand-content-wrapper">
      <div class="brand-logo-glow">
        <i class="bi bi-layers-half"></i>
      </div>
      <h1 class="brand-title">Team Task<br>Manager</h1>
      <p class="brand-subtitle">Empower your team with a collaborative platform to streamline projects, track progress, and hit deadlines together.</p>
      
      <!-- Mockup Widget -->
      <div class="mockup-widget">
        <div class="mockup-header">
          <span class="mockup-project">Project SilverStone</span>
          <span class="status-badge DONE">Completed</span>
        </div>
        <h5 class="mockup-title">User Authentication System</h5>
        <p class="mockup-desc">Implement secure JWT-based signup and login screens.</p>
        <div class="mockup-progress-wrapper">
          <div class="d-flex justify-content-between mb-1">
            <span class="mockup-progress-label">Progress</span>
            <span class="mockup-progress-val">100%</span>
          </div>
          <div class="progress modern-progress" style="height: 6px;">
            <div class="progress-bar bg-success" style="width: 100%"></div>
          </div>
        </div>
        <div class="mockup-footer">
          <div class="mockup-avatars">
            <div class="member-avatar-xs" style="background-color: #6366f1;">JD</div>
            <div class="member-avatar-xs" style="background-color: #ec4899; margin-left: -8px;">AM</div>
          </div>
          <span class="mockup-date text-success"><i class="bi bi-check-circle-fill me-1"></i>Verified</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Side: Signup Form -->
  <div class="auth-form-side">
    <div class="auth-card-modern">
      <div class="auth-header-modern">
        <h2>Create Account</h2>
        <p>Get started with Team Task Manager today</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger-modern" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <%= error %>
        </div>
      <% } %>

      <form action="/signup" method="POST" class="auth-form-modern">
        <div class="form-group-modern mb-3">
          <label class="form-label-modern"><i class="bi bi-person me-2"></i>Full Name</label>
          <input
            type="text"
            name="name"
            class="form-control-modern"
            placeholder="John Doe"
            required
          />
        </div>

        <div class="form-group-modern mb-3">
          <label class="form-label-modern"><i class="bi bi-envelope me-2"></i>Email Address</label>
          <input
            type="email"
            name="email"
            class="form-control-modern"
            placeholder="name@company.com"
            required
          />
        </div>
        
        <div class="form-group-modern mb-3">
          <label class="form-label-modern"><i class="bi bi-lock me-2"></i>Password</label>
          <input
            type="password"
            name="password"
            class="form-control-modern"
            placeholder="Minimum 6 characters"
            required
          />
        </div>

        <div class="form-group-modern mb-4">
          <label class="form-label-modern"><i class="bi bi-shield-lock me-2"></i>Select Role</label>
          <select name="role" class="form-select-modern">
            <option value="MEMBER">Member (View & update tasks)</option>
            <option value="ADMIN">Admin (Full project control)</option>
          </select>
        </div>

        <button type="submit" class="btn btn-primary-modern w-100">
          Get Started <i class="bi bi-arrow-right ms-2"></i>
        </button>
      </form>

      <div class="auth-footer-modern">
        <p>Already have an account?<a href="/login">Sign in</a></p>
      </div>
    </div>
  </div>

</div>