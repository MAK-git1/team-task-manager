<div class="row g-4 mb-4">
  <!-- Main Content Column (Left) -->
  <div class="col-lg-8">
    <div class="dashboard-header mb-4">
      <h2 class="dashboard-title">
        Welcome <%= locals.user.name || locals.user.email.split('@')[0] %> 
      </h2>
      <p class="dashboard-subtitle">
        Take a look at your project overview and get started.
      </p>
    </div>

    <!-- Stats Cards (2x2 Grid) -->
    <div class="row g-4 mb-4">
      <!-- Total Tasks -->
      <div class="col-sm-6">
        <div class="stat-card-modern stat-card-primary h-100">
          <div class="stat-info">
            <span class="stat-label">Total Tasks</span>
            <h2 class="stat-value"><%= dashboardData.stats.totalTasks %></h2>
          </div>
          <div class="stat-icon-wrapper">
            <i class="bi bi-list-task"></i>
          </div>
        </div>
      </div>

      <!-- Completed -->
      <div class="col-sm-6">
        <div class="stat-card-modern stat-card-success h-100">
          <div class="stat-info">
            <span class="stat-label">Completed</span>
            <h2 class="stat-value"><%= dashboardData.stats.completedTasks %></h2>
          </div>
          <div class="stat-icon-wrapper">
            <i class="bi bi-check2-circle"></i>
          </div>
        </div>
      </div>

      <!-- Pending -->
      <div class="col-sm-6">
        <div class="stat-card-modern stat-card-warning h-100">
          <div class="stat-info">
            <span class="stat-label">Pending</span>
            <h2 class="stat-value"><%= dashboardData.stats.pendingTasks %></h2>
          </div>
          <div class="stat-icon-wrapper">
            <i class="bi bi-hourglass-split"></i>
          </div>
        </div>
      </div>

      <!-- Overdue -->
      <div class="col-sm-6">
        <div class="stat-card-modern stat-card-danger h-100">
          <div class="stat-info">
            <span class="stat-label">Overdue</span>
            <h2 class="stat-value text-danger"><%= dashboardData.stats.overdueTasksCount %></h2>
          </div>
          <div class="stat-icon-wrapper">
            <i class="bi bi-exclamation-octagon"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Project Progress -->
    <% if (dashboardData.projectSummaries && dashboardData.projectSummaries.length > 0) { %>
      <div class="dashboard-panel-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="dashboard-panel-title m-0">Ongoing Projects</h5>
          <a href="/projects" class="btn btn-sm btn-outline-primary rounded-pill px-3">View All</a>
        </div>
        <div class="row g-3">
          <% dashboardData.projectSummaries.forEach(project => { %>
            <div class="col-md-6">
              <div class="project-card-modern h-100">
                <div>
                  <h6 class="project-card-title text-gradient"><%= project.name %></h6>
                  <div class="d-flex justify-content-between align-items-center mb-2 mt-3">
                    <span class="small text-muted">Completion</span>
                    <span class="badge bg-primary-subtle text-primary fw-bold" style="font-size: 0.75rem;"><%= project.progress %>%</span>
                  </div>
                  <div class="progress mb-3" style="height: 6px; border-radius: 3px;">
                    <div class="progress-bar" style="width: <%= project.progress %>%; background: linear-gradient(90deg, #6366f1, #8b5cf6);"></div>
                  </div>
                </div>
                <div>
                  <div class="d-flex justify-content-between text-muted small mb-3 border-top pt-2 mt-2">
                    <span><i class="bi bi-check-circle me-1"></i><%= project.completedTasks %> Done</span>
                    <span><i class="bi bi-folder2 me-1"></i><%= project.totalTasks %> Total</span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Recent Tasks -->
    <div class="modern-table-card mb-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="dashboard-panel-title m-0">Recent Tasks</h5>
        <a href="/tasks" class="btn btn-sm btn-outline-primary rounded-pill px-3">View All</a>
      </div>
      <div class="table-responsive">
        <table class="table modern-table mb-0">
          <thead>
            <tr>
              <th>Task</th>
              <th>Status</th>
              <th>Priority</th>
            </tr>
          </thead>
          <tbody>
            <% dashboardData.recentTasks.forEach(task => { %>
              <tr>
                <td class="recent-task-title-cell">
                  <i class="bi bi-file-earmark-check me-2 text-muted"></i><%= task.title %>
                  <div class="small text-muted mt-1 d-block d-sm-none"><i class="bi bi-calendar3 me-1"></i><%= new Date(task.dueDate).toLocaleDateString() %></div>
                </td>
                <td>
                  <span class="badge status-badge <%= task.status %>">
                    <%= task.status %>
                  </span>
                </td>
                <td>
                  <span class="badge priority-badge <%= task.priority %>">
                    <%= task.priority %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Side Content Column (Right) -->
  <div class="col-lg-4">
    <!-- Tasks Chart -->
    <div class="dashboard-panel-card mb-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="dashboard-panel-title m-0">Task Breakdown</h5>
        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1 rounded-pill fw-bold" style="font-size: 0.75rem;">
          <%= dashboardData.stats.totalTasks %> Total
        </span>
      </div>
      <div style="height: 180px; position: relative;">
        <canvas id="tasksChart"></canvas> 
      </div>
    </div>

    <!-- Completion Progress -->
    <div class="dashboard-panel-card mb-4">
      <div>
        <h5 class="dashboard-panel-title mb-3">Overall Progress</h5>
        <p class="text-muted small">
          Your team's productivity rate across all projects.
        </p>
      </div>
      <div class="py-2">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="fw-bold text-main" style="font-size: 0.95rem;">Completion Rate</span>
          <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1 rounded-pill fw-bold">
            <%= dashboardData.stats.completionRate %>%
          </span>
        </div>
        <div class="progress modern-progress mb-3" style="height: 10px; border-radius: 5px;">
          <div
            class="progress-bar"
            style="
              width: <%= dashboardData.stats.completionRate %>%;
              background: linear-gradient(90deg, #6366f1, #8b5cf6);
            "
          ></div>
        </div>
      </div>
    </div>

    <!-- Overdue Tasks -->
    <% if (dashboardData.overdueTasks.length > 0) { %>
      <div class="overdue-card-modern mb-4">
        <h5 class="text-danger mb-4 d-flex align-items-center fw-bold" style="font-size: 1rem;">
          <i class="bi bi-exclamation-triangle-fill me-2"></i> Action Required
        </h5>
        <div class="d-flex flex-column gap-3">
          <% dashboardData.overdueTasks.forEach(task => { %>
            <div class="overdue-item-modern m-0 w-100 flex-column align-items-start">
              <span class="overdue-title-modern mb-2"><%= task.title %></span>
              <span class="overdue-date-modern w-100 text-end">
                <i class="bi bi-clock-fill me-1"></i> Due <%= new Date(task.dueDate).toLocaleDateString() %>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<!-- Chart JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctx = document.getElementById('tasksChart');
    if (ctx) {
      const chartCtx = ctx.getContext('2d');
      
      // Custom Linear Gradients for doughnut rings
      const gradCompleted = chartCtx.createLinearGradient(0, 0, 0, 220);
      gradCompleted.addColorStop(0, '#10b981');
      gradCompleted.addColorStop(1, '#047857');

      const gradPending = chartCtx.createLinearGradient(0, 0, 0, 220);
      gradPending.addColorStop(0, '#f59e0b');
      gradPending.addColorStop(1, '#b45309');

      const gradInProgress = chartCtx.createLinearGradient(0, 0, 0, 220);
      gradInProgress.addColorStop(0, '#3b82f6');
      gradInProgress.addColorStop(1, '#1d4ed8');

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Completed', 'Pending', 'In Progress'],
          datasets: [{
            data: [
              <%= dashboardData.stats.completedTasks %>,
              <%= dashboardData.stats.pendingTasks %>,
              <%= dashboardData.stats.inProgressTasks %>
            ],
            backgroundColor: [gradCompleted, gradPending, gradInProgress],
            borderRadius: 8,
            borderSkipped: false,
            barThickness: 28,
            maxBarThickness: 36,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              backgroundColor: 'rgba(15, 23, 42, 0.9)',
              titleFont: { family: "'Inter', sans-serif", size: 12, weight: '700' },
              bodyFont: { family: "'Inter', sans-serif", size: 12 },
              padding: 10,
              cornerRadius: 10,
              displayColors: false,
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(148, 163, 184, 0.08)',
              },
              border: {
                dash: [5, 5]
              },
              ticks: {
                stepSize: 1,
                font: { family: "'Inter', sans-serif", size: 10, weight: '500' }
              }
            },
            x: {
              grid: {
                display: false
              },
              ticks: {
                font: { family: "'Inter', sans-serif", size: 11, weight: '600' }
              }
            }
          }
        }
      });
    }
  });
</script>