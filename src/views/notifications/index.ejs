<div class="notifications-header mb-4">
  <h2 class="dashboard-title">Notifications</h2>
  <p class="dashboard-subtitle">Stay updated on your task activities.</p>
</div>

<div class="dashboard-card">
  <% if (notifications && notifications.length > 0) { %>
    <div class="list-group list-group-flush">
      <% notifications.forEach(notification => { %>
        <div class="list-group-item px-0 py-3 border-bottom <%= notification.isRead ? '' : 'bg-light' %>">
          <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex gap-3">
              <div class="notification-icon">
                <i class="bi bi-bell-fill text-primary"></i>
              </div>
              <div>
                <p class="mb-1 <%= notification.isRead ? '' : 'fw-bold' %>">
                  <%= notification.message %>
                </p>
                <small class="text-muted">
                  <%= new Date(notification.createdAt).toLocaleString() %>
                </small>
                <% if (notification.link) { %>
                  <div class="mt-2">
                    <a href="<%= notification.link %>" class="btn btn-sm btn-outline-primary">View Details</a>
                  </div>
                <% } %>
              </div>
            </div>
            <% if (!notification.isRead) { %>
              <span class="badge bg-primary rounded-pill">New</span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="bi bi-bell-slash text-muted" style="font-size: 3rem;"></i>
      <h5 class="mt-3">No notifications yet</h5>
      <p class="text-muted">We'll let you know when something important happens.</p>
    </div>
  <% } %>
</div>

<style>
.notification-icon {
  width: 40px;
  height: 40px;
  background: rgba(37, 99, 235, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.list-group-item {
  transition: 0.2s;
}
.list-group-item:hover {
  background: rgba(0,0,0,0.02);
}
</style>
