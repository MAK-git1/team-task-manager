<nav class="top-navbar" id="mainNavbar">

  <!-- LEFT: Brand + Navigation Links -->
  <div class="d-flex align-items-center gap-3">

    <!-- Brand Logo -->
    <a href="/" class="navbar-brand-wrap d-flex align-items-center gap-2 text-decoration-none">
      <div class="navbar-brand-logo">
        <i class="bi bi-layers-half"></i>
      </div>
      <div class="d-none d-sm-flex flex-column lh-1">
        <span class="navbar-brand-name">Task<span class="text-accent">Flow</span></span>
        <span class="navbar-brand-sub">WORKSPACE</span>
      </div>
    </a>

    <!-- Separator -->
    <div class="navbar-sep d-none d-md-block"></div>

    <!-- Navigation Links -->
    <ul class="nav navbar-nav-links d-none d-md-flex align-items-center gap-1 mb-0">
      <li class="nav-item">
        <a class="nav-link navbar-nav-link <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>" href="/">
          <i class="bi bi-grid-fill"></i>
          <span>Dashboard</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link navbar-nav-link <%= typeof title !== 'undefined' && (title === 'Projects' || title === 'Project Details') ? 'active' : '' %>" href="/projects">
          <i class="bi bi-folder2-open"></i>
          <span>Projects</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link navbar-nav-link <%= typeof title !== 'undefined' && title === 'Tasks' ? 'active' : '' %>" href="/tasks">
          <i class="bi bi-check2-square"></i>
          <span>Tasks</span>
        </a>
      </li>
    </ul>
  </div>

  <!-- RIGHT: Actions + User Profile -->
  <div class="d-flex align-items-center gap-2">

    <!-- Mobile Hamburger Menu -->
    <div class="dropdown d-md-none">
      <button class="navbar-icon-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Menu">
        <i class="bi bi-list fs-5"></i>
      </button>
      <ul class="dropdown-menu dropdown-menu-end mt-2">
        <li><a class="dropdown-item <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>" href="/"><i class="bi bi-grid-fill me-2 text-primary"></i>Dashboard</a></li>
        <li><a class="dropdown-item <%= typeof title !== 'undefined' && (title === 'Projects' || title === 'Project Details') ? 'active' : '' %>" href="/projects"><i class="bi bi-folder2-open me-2 text-indigo"></i>Projects</a></li>
        <li><a class="dropdown-item <%= typeof title !== 'undefined' && title === 'Tasks' ? 'active' : '' %>" href="/tasks"><i class="bi bi-check2-square me-2 text-violet"></i>Tasks</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger" href="/logout" onclick="return confirmAction('Logout from application?')"><i class="bi bi-power me-2"></i>Logout</a></li>
      </ul>
    </div>

    <% if (locals.user) { %>

      <!-- Theme Toggle -->
      <button id="theme-toggle" class="navbar-icon-btn d-none d-sm-flex" title="Toggle Theme">
        <i class="bi bi-moon"></i>
      </button>

      <!-- Notification Bell -->
      <a href="/notifications" class="navbar-icon-btn position-relative d-none d-sm-flex" title="Notifications">
        <i class="bi bi-bell"></i>
        <% if (locals.unreadCount > 0) { %>
          <span class="notification-pulse-badge">
            <%= locals.unreadCount > 9 ? '9+' : locals.unreadCount %>
          </span>
        <% } %>
      </a>

      <!-- Vertical Divider -->
      <div class="navbar-sep-v d-none d-sm-block"></div>

      <!-- User Info + Avatar Dropdown -->
      <div class="d-flex align-items-center gap-2">
        <!-- Name/Role text (desktop) -->
        <div class="text-end d-none d-lg-block">
          <div class="navbar-user-name"><%= locals.user.name || locals.user.email.split('@')[0] %></div>
          <div class="navbar-user-role"><%= locals.user.role %></div>
        </div>

        <!-- Avatar Dropdown -->
        <div class="dropdown">
          <button class="navbar-avatar dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Account">
            <%= locals.user.email.charAt(0).toUpperCase() %>
          </button>

          <ul class="dropdown-menu dropdown-menu-end mt-2 navbar-dropdown-menu">
            <!-- Mobile user info header -->
            <li class="d-lg-none px-3 pt-2 pb-3 mb-1 navbar-dropdown-header">
              <div class="d-flex align-items-center gap-3">
                <div class="navbar-dropdown-avatar">
                  <%= locals.user.email.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="fw-bold text-main" style="font-size: 0.9rem;"><%= locals.user.name || locals.user.email.split('@')[0] %></div>
                  <small class="text-muted" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;"><%= locals.user.role %></small>
                </div>
              </div>
            </li>

            <li>
              <a class="dropdown-item navbar-dropdown-item" href="/profile">
                <span class="navbar-dropdown-icon bg-primary-subtle text-primary"><i class="bi bi-person-fill"></i></span>
                <span>Profile</span>
              </a>
            </li>
            <li>
              <a class="dropdown-item navbar-dropdown-item" href="/settings">
                <span class="navbar-dropdown-icon bg-indigo-subtle text-indigo"><i class="bi bi-gear-fill"></i></span>
                <span>Settings</span>
              </a>
            </li>

            <li><hr class="dropdown-divider my-2"></li>

            <li>
              <a class="dropdown-item navbar-dropdown-item text-danger" href="/logout" onclick="return confirmAction('Logout from application?')">
                <span class="navbar-dropdown-icon bg-danger-subtle text-danger"><i class="bi bi-box-arrow-right"></i></span>
                <span>Sign Out</span>
              </a>
            </li>
          </ul>
        </div>
      </div>

    <% } %>
  </div>
</nav>