<%# Flash messages from redirect query params %>
<% const errorMsg = (typeof locals.error !== 'undefined' && locals.error) ? locals.error : (typeof query !== 'undefined' && query && query.error) ? query.error : null; %>
<% const successMsg = (typeof locals.success !== 'undefined' && locals.success) ? locals.success : (typeof query !== 'undefined' && query && query.success) ? query.success : null; %>

<% if (errorMsg) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= errorMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (successMsg) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= successMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="project-details-header">

  <div>

    <h2 class="dashboard-title">
      <%= project.name %>
    </h2>

    <p class="dashboard-subtitle">
      <%= project.description || 'No description provided.' %>
    </p>

  </div>

  <% if (locals.user && locals.user.role === 'ADMIN') { %>
    <button
      class="btn btn-primary"
      data-bs-toggle="modal"
      data-bs-target="#addMemberModal"
    >
      <i class="bi bi-person-plus"></i>
      Add Member
    </button>
  <% } %>

</div>

<div class="row g-4 mt-2">
  <!-- Left Side: Team Members list -->
  <div class="col-lg-4">
    <div class="dashboard-panel-card h-100 shadow-sm p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="dashboard-panel-title m-0">Team Members</h5>
        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1 rounded-pill fw-bold" style="font-size: 0.75rem;">
          <%= project.members.length %>
        </span>
      </div>

      <% if (locals.user && locals.user.role === 'ADMIN') { %>
        <div class="alert mb-4 shadow-sm border-0 d-flex align-items-start gap-2.5" style="background: rgba(99, 102, 241, 0.06); border-radius: 12px; font-size: 0.8rem; padding: 12px;">
          <i class="bi bi-info-circle-fill text-primary fs-5"></i>
          <div>
            <strong>Project Access:</strong> Signed-up users must be manually added. Use the <strong>"Add Member"</strong> button above.
          </div>
        </div>
      <% } %>

      <div class="d-flex flex-column gap-3">
        <% if (project.members && project.members.length > 0) { %>
          <% project.members.forEach((member, idx) => { %>
            <% if (member && member.user) { %>
              <div class="d-flex align-items-center gap-3 p-2.5 rounded-3 hover-bg-transition" style="border: 1px solid transparent; transition: all 0.2s ease;">
                <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                     style="width: 40px; height: 40px; border-radius: 10px; font-size: 0.95rem; background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                  <%= member.user.email.charAt(0).toUpperCase() %>
                </div>
                <div class="flex-grow-1">
                  <div class="fw-bold text-main" style="font-size: 0.9rem; line-height: 1.2;">
                    <%= member.user.name || 'Unknown User' %>
                  </div>
                  <small class="text-muted" style="font-size: 0.75rem; word-break: break-all;"><%= member.user.email %></small>
                </div>
              </div>
            <% } %>
          <% }) %>
        <% } else { %>
          <div class="text-center py-4 text-muted">
            <i class="bi bi-people text-muted fs-2 mb-2 d-block"></i>
            <p class="small mb-0">No members added yet.</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Side: Project Overview & Task List -->
  <div class="col-lg-8">
    <div class="d-flex flex-column gap-4">
      
      <!-- Project Overview Stats -->
      <div class="dashboard-panel-card shadow-sm p-4">
        <h5 class="dashboard-panel-title mb-4">Project Overview</h5>
        <div class="row g-3">
          
          <!-- Total Members Stat -->
          <div class="col-sm-4">
            <div class="p-4 rounded-4 text-center h-100" style="background: rgba(99, 102, 241, 0.03); border: 1.5px solid var(--border-color);">
              <span class="text-muted d-block small mb-2 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.7rem;">Members</span>
              <h3 class="fw-extrabold text-primary mb-0" style="font-size: 1.8rem;"><%= project.members ? project.members.length : 0 %></h3>
            </div>
          </div>
          
          <!-- Creator Stat -->
          <div class="col-sm-4">
            <div class="p-4 rounded-4 text-center h-100 d-flex flex-column justify-content-center" style="background: rgba(16, 185, 129, 0.03); border: 1.5px solid var(--border-color);">
              <span class="text-muted d-block small mb-2 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.7rem;">Created By</span>
              <h6 class="fw-bold text-success mb-0" style="font-size: 0.95rem; word-break: break-all;">
                <%= (project.createdBy && project.createdBy.name) ? project.createdBy.name : 'N/A' %>
              </h6>
            </div>
          </div>

          <!-- Date Stat -->
          <div class="col-sm-4">
            <div class="p-4 rounded-4 text-center h-100 d-flex flex-column justify-content-center" style="background: rgba(245, 158, 11, 0.03); border: 1.5px solid var(--border-color);">
              <span class="text-muted d-block small mb-2 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.7rem;">Created Date</span>
              <h6 class="fw-bold text-warning mb-0" style="font-size: 0.95rem;">
                <%= new Date(project.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </h6>
            </div>
          </div>

        </div>
      </div>

      <!-- Project Tasks Table -->
      <div class="modern-table-card shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="dashboard-panel-title m-0">Project Tasks</h5>
          <% if (locals.user && locals.user.role === 'ADMIN') { %>
            <a href="/tasks?projectId=<%= project.id %>" class="btn btn-sm btn-primary rounded-pill px-3">
              <i class="bi bi-plus-lg me-1"></i> Add Task
            </a>
          <% } %>
        </div>

        <div class="table-responsive">
          <table class="table modern-table mb-0">
            <thead>
              <tr>
                <th>Task Title</th>
                <th>Assigned To</th>
                <th>Priority</th>
                <th>Due Date</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (project.tasks && project.tasks.length > 0) { %>
                <% project.tasks.forEach(task => { %>
                  <tr>
                    <td class="fw-semibold text-main"><%= task.title %></td>
                    <td>
                      <% if (task.assignedTo) { %>
                        <div class="d-flex align-items-center gap-2">
                          <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                               style="width: 26px; height: 26px; border-radius: 50%; font-size: 0.75rem; background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                            <%= task.assignedTo.name.charAt(0).toUpperCase() %>
                          </div>
                          <span style="font-size: 0.85rem;" class="text-main"><%= task.assignedTo.name %></span>
                        </div>
                      <% } else { %>
                        <span class="text-muted small">Unassigned</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="badge priority-badge <%= task.priority %>">
                        <%= task.priority %>
                      </span>
                    </td>
                    <td class="recent-task-date-cell">
                      <i class="bi bi-calendar3 me-1"></i><%= new Date(task.dueDate).toLocaleDateString() %>
                    </td>
                    <td>
                      <% const canUpdate = locals.user && (locals.user.role === 'ADMIN' || (task.assignedTo && String(task.assignedTo.id) === String(locals.user.id))); %>
                      <% if (canUpdate) { %>
                        <form action="/tasks/<%= task.id %>/status" method="POST" class="d-flex align-items-center gap-1.5">
                          <select name="status" class="form-select form-select-sm rounded-pill" style="min-width:115px; font-size: 0.75rem; padding: 4px 8px;">
                            <option value="TODO" <%= task.status === 'TODO' ? 'selected' : '' %>>TODO</option>
                            <option value="IN_PROGRESS" <%= task.status === 'IN_PROGRESS' ? 'selected' : '' %>>IN_PROGRESS</option>
                            <option value="DONE" <%= task.status === 'DONE' ? 'selected' : '' %>>DONE</option>
                          </select>
                          <button type="submit" class="btn btn-sm btn-primary rounded-pill px-2.5 py-1" style="font-size: 0.75rem;">Save</button>
                        </form>
                      <% } else { %>
                        <span class="badge status-badge <%= task.status %>">
                          <%= task.status %>
                        </span>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <a href="/tasks/<%= task.id %>" class="btn btn-sm btn-outline-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 32px; height: 32px; padding: 0;">
                        <i class="bi bi-eye-fill"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">No tasks in this project yet.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Add Member Modal (Admin Only) -->
<% if (locals.user && locals.user.role === 'ADMIN') { %>

<div
  class="modal fade"
  id="addMemberModal"
  tabindex="-1"
>

  <div class="modal-dialog">

    <div class="modal-content modern-modal">

      <div class="modal-header">

        <h5 class="modal-title">
          Add Member to Project
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>

      </div>

      <form
        action="/projects/<%= project.id %>/add-member"
        method="POST"
      >

        <div class="modal-body">

          <div class="mb-3">
            <label class="form-label fw-semibold">Select User</label>

            <select
              name="userId"
              class="form-select"
              required
            >
              <option value="" disabled selected>-- Select a user --</option>

              <% if (locals.allUsers && allUsers.length > 0) { %>

                <% const memberIds = project.members ? project.members.map(m => m.user ? m.user.id : null) : []; %>

                <% allUsers.forEach(u => { %>
                  <% if (!memberIds.includes(u.id)) { %>
                    <option value="<%= u.id %>">
                      <%= u.name %> (<%= u.email %>)
                    </option>
                  <% } %>
                <% }) %>

              <% } else { %>
                <option disabled>No users available to add</option>
              <% } %>

            </select>
          </div>

        </div>

        <div class="modal-footer">

          <button
            type="submit"
            class="btn btn-primary"
          >
            Add Member
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

<% } %>

<script>
// Read query params and show alerts
const urlParams = new URLSearchParams(window.location.search);
const pageError = urlParams.get('error');
const pageSuccess = urlParams.get('success');

if (pageError) {
  const el = document.createElement('div');
  el.className = 'alert alert-danger alert-dismissible fade show mt-3';
  el.innerHTML = pageError + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  document.body.prepend(el);
}
if (pageSuccess) {
  const el = document.createElement('div');
  el.className = 'alert alert-success alert-dismissible fade show mt-3';
  el.innerHTML = pageSuccess + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  document.body.prepend(el);
}
</script>