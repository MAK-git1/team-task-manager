<script>
// Show redirect-based flash messages
const urlParams = new URLSearchParams(window.location.search);
const pageError = urlParams.get('error');
const pageSuccess = urlParams.get('success');
document.addEventListener('DOMContentLoaded', function() {
  if (pageError) {
    const mainContent = document.querySelector('.main-content') || document.body;
    const el = document.createElement('div');
    el.className = 'alert alert-danger alert-dismissible fade show mb-3';
    el.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>' + decodeURIComponent(pageError) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    mainContent.prepend(el);
  }
  if (pageSuccess) {
    const mainContent = document.querySelector('.main-content') || document.body;
    const el = document.createElement('div');
    el.className = 'alert alert-success alert-dismissible fade show mb-3';
    el.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + decodeURIComponent(pageSuccess) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    mainContent.prepend(el);
  }
});
</script>

<div class="d-flex justify-content-between align-items-center mb-4">

  <div>

    <h2 class="dashboard-title">
      Projects
    </h2>

    <p class="dashboard-subtitle">
      Manage your team projects.
    </p>

  </div>

  <% if (locals.user && locals.user.role === 'ADMIN') { %>
    <button
      class="btn btn-primary"
      data-bs-toggle="modal"
      data-bs-target="#createProjectModal"
    >
      <i class="bi bi-plus-lg"></i>
      Create Project
    </button>
  <% } %>

</div>

<!-- Projects Grid -->
<div class="row g-4">
  <% if (projects.length > 0) { %>
    <% projects.forEach(project => { %>
      <div class="col-md-6 col-lg-4">
        <div class="project-card-modern shadow-sm h-100 d-flex flex-column justify-content-between p-4" style="border-radius: 20px; background: var(--card-bg); border: 1px solid var(--border-color);">
          
          <div>
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h5 class="fw-bold text-gradient mb-0" style="font-size: 1.15rem; letter-spacing: -0.3px;">
                <%= project.name %>
              </h5>
              <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1 rounded-pill" style="font-size: 0.7rem; font-weight: 700;">
                ACTIVE
              </span>
            </div>
            
            <p class="text-muted small mb-4" style="line-height: 1.5; min-height: 48px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              <%= project.description || 'No description available' %>
            </p>
            
            <!-- Member stack -->
            <div class="mb-4">
              <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Team Members</small>
              <div class="d-flex align-items-center">
                <% if (project.members && project.members.length > 0) { %>
                  <div class="d-flex">
                    <% project.members.slice(0, 4).forEach((m, idx) => { %>
                      <% if (m && m.user) { %>
                        <span class="member-avatar-badge" 
                              style="background-color: <%= ['#6366f1', '#ec4899', '#10b981', '#f59e0b', '#3b82f6'][idx % 5] %>; margin-left: <%= idx > 0 ? '-10px' : '0' %>; border: 2.5px solid var(--card-bg);" 
                              title="<%= m.user.name || m.user.email %>">
                          <%= (m.user.name || m.user.email).substring(0, 2).toUpperCase() %>
                        </span>
                      <% } %>
                    <% }) %>
                    <% if (project.members.length > 4) { %>
                      <span class="member-avatar-badge bg-secondary text-white d-flex align-items-center justify-content-center" 
                            style="margin-left: -10px; border: 2.5px solid var(--card-bg);" 
                            title="And <%= project.members.length - 4 %> more">
                        +<%= project.members.length - 4 %>
                      </span>
                    <% } %>
                  </div>
                <% } else { %>
                  <span class="text-muted small italic">No members assigned</span>
                <% } %>
              </div>
            </div>
          </div>

          <div>
            <div class="d-flex justify-content-between align-items-center text-muted small border-top pt-3 mt-2">
              <span class="d-flex align-items-center gap-1.5"><i class="bi bi-people-fill text-primary"></i> <%= project.members.length %> Members</span>
              <span class="d-flex align-items-center gap-1.5"><i class="bi bi-calendar3 text-info"></i> <%= new Date(project.createdAt).toLocaleDateString() %></span>
            </div>

            <div class="d-flex gap-2 mt-4">
              <a href="/projects/<%= project.id %>" class="btn btn-primary flex-grow-1 rounded-pill fw-semibold shadow-sm d-flex align-items-center justify-content-center gap-1.5" style="font-size: 0.85rem; padding: 10px 16px;">
                <i class="bi bi-folder-symlink-fill"></i> Open Workspace
              </a>
              <% if (locals.user && locals.user.role === 'ADMIN') { %>
                <form action="/projects/<%= project.id %>/delete" method="POST" 
                      onsubmit="const first = confirmAction('Delete project &quot;<%= project.name %>&quot;? This will also delete all its tasks.'); if(!first) return false; return confirmAction('Are you ABSOLUTELY sure? This action cannot be undone.');"
                      class="d-inline">
                  <button type="submit" class="btn btn-outline-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; padding: 0;" title="Delete Project">
                    <i class="bi bi-trash-fill"></i>
                  </button>
                </form>
              <% } %>
            </div>
          </div>

        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12">
      <div class="empty-state p-5 text-center" style="background: var(--card-bg); border-radius: 24px; border: 2px dashed var(--border-color);">
        <i class="bi bi-kanban text-muted display-3 mb-3 d-block"></i>
        <h4 class="fw-bold">No Projects Found</h4>
        <p class="text-muted">Create your first project to begin managing tasks.</p>
      </div>
    </div>
  <% } %>
</div>

<!-- Create Project Modal -->

<div
  class="modal fade"
  id="createProjectModal"
  tabindex="-1"
>

  <div class="modal-dialog">

    <div class="modal-content modern-modal">

      <div class="modal-header">

        <h5 class="modal-title">
          Create Project
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>

      </div>

      <form
        action="/projects/create"
        method="POST"
      >

        <div class="modal-body">

          <div class="mb-3">

            <label>
              Project Name
            </label>

            <input
              type="text"
              name="name"
              class="form-control"
              required
            />

          </div>

          <div class="mb-3">

            <label>
              Description
            </label>

            <textarea
              name="description"
              rows="4"
              class="form-control"
            ></textarea>

          </div>

        </div>

        <div class="modal-footer">

          <button
            type="submit"
            class="btn btn-primary"
          >
            Create Project
          </button>

        </div>

      </form>

    </div>

  </div>

</div>