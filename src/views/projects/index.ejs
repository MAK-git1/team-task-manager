<script>
// Show redirect-based flash messages
const urlParams = new URLSearchParams(window.location.search);
const pageError = urlParams.get('error');
const pageSuccess = urlParams.get('success');
document.addEventListener('DOMContentLoaded', function() {
  if (pageError) {
    const mainContent = document.querySelector('.main-content') || document.body;
    const el = document.createElement('div');
    el.className = 'alert alert-danger alert-dismissible fade show mb-3';
    el.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>' + decodeURIComponent(pageError) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    mainContent.prepend(el);
  }
  if (pageSuccess) {
    const mainContent = document.querySelector('.main-content') || document.body;
    const el = document.createElement('div');
    el.className = 'alert alert-success alert-dismissible fade show mb-3';
    el.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + decodeURIComponent(pageSuccess) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    mainContent.prepend(el);
  }
});
</script>

<div class="d-flex justify-content-between align-items-center mb-4">

  <div>

    <h2 class="dashboard-title">
      Projects
    </h2>

    <p class="dashboard-subtitle">
      Manage your team projects.
    </p>

  </div>

  <% if (locals.user && locals.user.role === 'ADMIN') { %>
    <button
      class="btn btn-primary"
      data-bs-toggle="modal"
      data-bs-target="#createProjectModal"
    >
      <i class="bi bi-plus-lg"></i>
      Create Project
    </button>
  <% } %>

</div>

<!-- Projects Grid -->

<div class="row g-4">

  <% if (projects.length > 0) { %>

    <% projects.forEach(project => { %>

      <div class="col-lg-4">

        <div class="project-card">

          <div class="project-card-header">

            <h5>
              <%= project.name %>
            </h5>

          </div>

          <p class="project-description">

            <%= project.description || 'No description available' %>

          </p>

          <div class="project-meta">

            <div>
              <i class="bi bi-people"></i>

              <%= project.members.length %>
              Members
            </div>

            <div>
              <i class="bi bi-calendar"></i>

              <%= new Date(project.createdAt)
              .toLocaleDateString() %>
            </div>

          </div>

          <a
            href="/projects/<%= project.id %>"
            class="btn btn-dark mt-4 w-100"
          >
            Open Project
          </a>

          <% if (locals.user && locals.user.role === 'ADMIN') { %>
            <form
              action="/projects/<%= project.id %>/delete"
              method="POST"
              onsubmit="const first = confirmAction('Delete project &quot;<%= project.name %>&quot;? This will also delete all its tasks.'); if(!first) return false; return confirmAction('Are you ABSOLUTELY sure? This action cannot be undone.');"
              class="mt-2"
            >
              <button type="submit" class="btn btn-outline-danger w-100">
                <i class="bi bi-trash me-1"></i>Delete Project
              </button>
            </form>
          <% } %>

        </div>

      </div>

    <% }) %>

  <% } else { %>

    <div class="empty-state">

      <i class="bi bi-kanban"></i>

      <h4>
        No Projects Found
      </h4>

      <p>
        Create your first project to begin.
      </p>

    </div>

  <% } %>

</div>

<!-- Create Project Modal -->

<div
  class="modal fade"
  id="createProjectModal"
  tabindex="-1"
>

  <div class="modal-dialog">

    <div class="modal-content modern-modal">

      <div class="modal-header">

        <h5 class="modal-title">
          Create Project
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>

      </div>

      <form
        action="/projects/create"
        method="POST"
      >

        <div class="modal-body">

          <div class="mb-3">

            <label>
              Project Name
            </label>

            <input
              type="text"
              name="name"
              class="form-control"
              required
            />

          </div>

          <div class="mb-3">

            <label>
              Description
            </label>

            <textarea
              name="description"
              rows="4"
              class="form-control"
            ></textarea>

          </div>

        </div>

        <div class="modal-footer">

          <button
            type="submit"
            class="btn btn-primary"
          >
            Create Project
          </button>

        </div>

      </form>

    </div>

  </div>

</div>