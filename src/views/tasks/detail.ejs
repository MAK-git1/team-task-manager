<%
  const errorMsg = (typeof locals.error !== 'undefined' && locals.error) ? locals.error : null;
  const successMsg = (typeof locals.success !== 'undefined' && locals.success) ? locals.success : null;
  const canUpdate = locals.user && (
    locals.user.role === 'ADMIN' ||
    (task.assignedTo && String(task.assignedTo.id) === String(locals.user.id))
  );
%>

<% if (errorMsg) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i><%= errorMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (successMsg) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i><%= successMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Back Button -->
<div class="mb-4">
  <a href="/tasks" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i> Back to Tasks
  </a>
</div>

<!-- Task Header/Body Layout -->
<div class="row g-4 mt-2">
  <!-- Left Side: Task Content, Attachments, Comments -->
  <div class="col-lg-8">
    <div class="d-flex flex-column gap-4">
      
      <!-- Main Task Card -->
      <div class="dashboard-panel-card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
          <div>
            <h2 class="dashboard-title text-gradient mb-2" style="font-size: 1.6rem;"><%= task.title %></h2>
            <div class="d-flex flex-wrap gap-2 align-items-center">
              <span class="badge status-badge <%= task.status %>"><%= task.status %></span>
              <span class="badge priority-badge <%= task.priority %>"><%= task.priority %></span>
              <% if (new Date(task.dueDate) < new Date() && task.status !== 'DONE') { %>
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-0.5 rounded-pill" style="font-size: 0.7rem; font-weight: 700;">OVERDUE</span>
              <% } %>
            </div>
          </div>

          <% if (canUpdate) { %>
            <div>
              <form action="/tasks/<%= task.id %>/status" method="POST" class="d-flex align-items-center gap-1.5">
                <select name="status" class="form-select form-select-sm rounded-pill" style="min-width:130px; font-size: 0.8rem; padding: 6px 12px;">
                  <option value="TODO" <%= task.status === 'TODO' ? 'selected' : '' %>>📋 TODO</option>
                  <option value="IN_PROGRESS" <%= task.status === 'IN_PROGRESS' ? 'selected' : '' %>>🔄 IN PROGRESS</option>
                  <option value="DONE" <%= task.status === 'DONE' ? 'selected' : '' %>>✅ DONE</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 py-1.5" style="font-size: 0.8rem;">Save</button>
              </form>
            </div>
          <% } %>
        </div>

        <h6 class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Description</h6>
        <p class="text-main" style="line-height: 1.6; white-space: pre-wrap;"><%= task.description || 'No description provided.' %></p>
      </div>

      <!-- Attachments Section -->
      <div class="dashboard-panel-card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="dashboard-panel-title m-0">
            <i class="bi bi-paperclip me-2 text-primary"></i> Attachments
          </h5>
          <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-0.5 rounded-pill fw-bold" style="font-size: 0.75rem;">
            <%= (task.attachments || []).length %>
          </span>
        </div>

        <% if (task.attachments && task.attachments.length > 0) { %>
          <div class="row g-3 mb-4">
            <% task.attachments.forEach(file => { %>
              <div class="col-sm-6">
                <div class="file-card p-3 border rounded-3 d-flex align-items-center gap-3" style="background: rgba(0, 0, 0, 0.01); border-color: var(--border-color) !important; transition: all 0.2s ease;">
                  <div class="file-icon bg-primary-subtle text-primary p-2.5 rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <% if (file.mimeType.startsWith('image/')) { %>
                      <i class="bi bi-image-fill fs-5"></i>
                    <% } else if (file.mimeType.includes('pdf')) { %>
                      <i class="bi bi-file-pdf-fill fs-5 text-danger"></i>
                    <% } else { %>
                      <i class="bi bi-file-earmark-arrow-down-fill fs-5"></i>
                    <% } %>
                  </div>
                  <div class="overflow-hidden flex-grow-1">
                    <div class="text-truncate fw-semibold text-main" style="font-size: 0.85rem;" title="<%= file.originalName %>">
                      <%= file.originalName %>
                    </div>
                    <div class="text-muted" style="font-size: 0.7rem;">
                      <%= (file.size / 1024).toFixed(1) %> KB
                    </div>
                  </div>
                  <a href="/uploads/<%= file.filename %>" target="_blank" class="btn btn-sm btn-outline-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; padding: 0;">
                    <i class="bi bi-download"></i>
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-4 text-muted border border-dashed rounded-3 mb-4" style="border-color: var(--border-color) !important;">
            <i class="bi bi-file-earmark text-muted fs-3 mb-2 d-block"></i>
            <p class="small mb-0">No files attached to this task.</p>
          </div>
        <% } %>

        <% if (canUpdate) { %>
          <div class="border-top pt-3">
            <form action="/tasks/<%= task.id %>/upload" method="POST" enctype="multipart/form-data" class="d-flex align-items-center gap-2">
              <input type="file" name="file" class="form-control form-control-sm rounded-pill" required>
              <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1.5" style="font-size: 0.8rem;">
                <i class="bi bi-upload me-1"></i> Upload Attachment
              </button>
            </form>
          </div>
        <% } %>
      </div>

      <!-- Comments Section -->
      <div class="dashboard-panel-card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="dashboard-panel-title m-0">
            <i class="bi bi-chat-left-text me-2 text-primary"></i> Comments
          </h5>
          <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-0.5 rounded-pill fw-bold" style="font-size: 0.75rem;">
            <%= (task.comments || []).length %>
          </span>
        </div>

        <% if (task.comments && task.comments.length > 0) { %>
          <div class="d-flex flex-column gap-3 mb-4" id="comments-list">
            <% task.comments.slice().reverse().forEach(comment => { %>
              <div class="d-flex gap-3 align-items-start p-3 rounded-3" style="background: rgba(99, 102, 241, 0.03); border: 1px solid var(--border-color);">
                <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm flex-shrink-0" 
                     style="width: 36px; height: 36px; border-radius: 50%; font-size: 0.85rem; background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                  <%= comment.author ? comment.author.name.charAt(0).toUpperCase() : '?' %>
                </div>
                <div class="flex-grow-1">
                  <div class="d-flex align-items-center justify-content-between mb-1.5">
                    <strong class="text-main" style="font-size: 0.85rem;"><%= comment.author ? comment.author.name : 'Unknown' %></strong>
                    <span class="text-muted" style="font-size: 0.7rem;">
                      <%= new Date(comment.createdAt).toLocaleString(undefined, { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                    </span>
                  </div>
                  <div class="comment-body text-main" style="font-size: 0.85rem; line-height: 1.5; white-space: pre-wrap;"><%= comment.content %></div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-4 text-muted border border-dashed rounded-3 mb-4" style="border-color: var(--border-color) !important;" id="no-comments">
            <i class="bi bi-chat-square-text text-muted fs-3 mb-2 d-block"></i>
            <p class="small mb-0">No comments yet. Be the first to start the conversation!</p>
          </div>
        <% } %>

        <% if (canUpdate) { %>
          <div class="border-top pt-4">
            <h6 class="mb-3 fw-bold text-main" style="font-size: 0.9rem;">Add a Comment</h6>
            <form action="/tasks/<%= task.id %>/comment" method="POST" id="commentForm">
              <div class="mb-3">
                <textarea name="content" id="commentContent" class="form-control" rows="3" placeholder="Write comment or progress update..." required style="resize:vertical; border-radius: 12px;"></textarea>
              </div>
              <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold" id="submitCommentBtn" style="font-size: 0.85rem;">
                  <i class="bi bi-send-fill me-1"></i> Post Comment
                </button>
              </div>
            </form>
          </div>
        <% } else { %>
          <div class="alert mb-0 shadow-sm border-0 d-flex align-items-center gap-2.5" style="background: rgba(99, 102, 241, 0.05); border-radius: 12px; font-size: 0.8rem;">
            <i class="bi bi-info-circle-fill text-primary fs-5"></i>
            <span>Only assigned members or administrators can post comments.</span>
          </div>
        <% } %>
      </div>

    </div>
  </div>

  <!-- Right Side: Task Details Sidebar (Metadata Card) -->
  <div class="col-lg-4">
    <div class="dashboard-panel-card shadow-sm p-4">
      <h5 class="dashboard-panel-title mb-4">Task Details</h5>

      <div class="d-flex flex-column gap-4">
        
        <!-- Assigned To -->
        <div>
          <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Assigned Member</small>
          <% if (task.assignedTo) { %>
            <div class="d-flex align-items-center gap-3">
              <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                   style="width: 42px; height: 42px; border-radius: 10px; font-size: 1rem; background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                <%= task.assignedTo.name.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div class="fw-bold text-main" style="font-size: 0.9rem; line-height: 1.2;"><%= task.assignedTo.name %></div>
                <small class="text-muted" style="font-size: 0.75rem; word-break: break-all;"><%= task.assignedTo.email %></small>
              </div>
            </div>
          <% } else { %>
            <span class="text-muted small italic">Unassigned</span>
          <% } %>
        </div>

        <!-- Created By -->
        <div>
          <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Created By</small>
          <% if (task.createdBy) { %>
            <div class="d-flex align-items-center gap-3">
              <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                   style="width: 42px; height: 42px; border-radius: 10px; font-size: 1rem; background: #94a3b8;">
                <%= task.createdBy.name.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div class="fw-bold text-main" style="font-size: 0.9rem; line-height: 1.2;"><%= task.createdBy.name %></div>
                <small class="text-muted" style="font-size: 0.75rem; word-break: break-all;"><%= task.createdBy.email %></small>
              </div>
            </div>
          <% } else { %>
            <span class="text-muted small italic">N/A</span>
          <% } %>
        </div>

        <!-- Project -->
        <div>
          <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Project Workspace</small>
          <div class="d-flex align-items-center gap-2.5">
            <div class="bg-primary-subtle text-primary d-flex align-items-center justify-content-center rounded-3" style="width: 32px; height: 32px;">
              <i class="bi bi-folder-fill fs-5"></i>
            </div>
            <strong class="text-main" style="font-size: 0.9rem;"><%= task.project ? task.project.name : 'N/A' %></strong>
          </div>
        </div>

        <!-- Due Date -->
        <div>
          <small class="text-muted d-block mb-2 fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Due Date</small>
          <div class="d-flex align-items-center gap-2.5">
            <div class="d-flex align-items-center justify-content-center rounded-3 <%= new Date(task.dueDate) < new Date() && task.status !== 'DONE' ? 'bg-danger-subtle text-danger' : 'bg-info-subtle text-info' %>" style="width: 32px; height: 32px;">
              <i class="bi bi-calendar-event-fill fs-5"></i>
            </div>
            <strong class="text-main" style="font-size: 0.9rem;">
              <%= new Date(task.dueDate).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </strong>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
// Read query params and show alerts
const urlParams = new URLSearchParams(window.location.search);
const pageError = urlParams.get('error');
const pageSuccess = urlParams.get('success');

if (pageError && !document.querySelector('.alert-danger')) {
  const mainContent = document.querySelector('.main-content') || document.body;
  const el = document.createElement('div');
  el.className = 'alert alert-danger alert-dismissible fade show';
  el.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>' + decodeURIComponent(pageError) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  mainContent.prepend(el);
}
if (pageSuccess && !document.querySelector('.alert-success')) {
  const mainContent = document.querySelector('.main-content') || document.body;
  const el = document.createElement('div');
  el.className = 'alert alert-success alert-dismissible fade show';
  el.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + decodeURIComponent(pageSuccess) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  mainContent.prepend(el);
}

// Prevent double-submit on comment form
const commentForm = document.getElementById('commentForm');
const submitBtn = document.getElementById('submitCommentBtn');
if (commentForm && submitBtn) {
  commentForm.addEventListener('submit', () => {
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Posting...';
  });
}
</script>

<style>
.comment-item {
  animation: fadeInUp 0.3s ease;
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
