<% const errorMsg = (typeof locals.error !== 'undefined' && locals.error) ? locals.error : null; %>
<% const successMsg = (typeof locals.success !== 'undefined' && locals.success) ? locals.success : null; %>

<% if (errorMsg) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i><%= errorMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (successMsg) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i><%= successMsg %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="d-flex justify-content-between align-items-center mb-4">

  <div>

    <h2 class="dashboard-title">
      Tasks
    </h2>

    <p class="dashboard-subtitle">
      Manage and track project tasks.
    </p>

  </div>

  <% if (locals.user && locals.user.role === 'ADMIN') { %>
    <button
      class="btn btn-primary"
      data-bs-toggle="modal"
      data-bs-target="#createTaskModal"
    >
      <i class="bi bi-plus-lg"></i>
      Create Task
    </button>
  <% } %>

</div>

<!-- Tasks Table -->

<div class="dashboard-card">

  <div class="table-responsive">

    <table class="table modern-table">

      <thead>

        <tr>
          <th>Task</th>
          <th>Project</th>
          <th>Assigned To</th>
          <th>Created By</th>
          <th>Status</th>
          <th>Priority</th>
          <th>Due Date</th>
          <th>Actions</th>
        </tr>

      </thead>

      <tbody>

        <% if (tasks.length > 0) { %>

          <% tasks.forEach(task => { %>

            <tr class="
              <%= new Date(task.dueDate) < new Date()
              && task.status !== 'DONE'
              ? 'overdue-row'
              : '' %>
            ">

              <td>
                <strong>
                  <%= task.title %>
                </strong>
                <% if (task.description) { %>
                  <div class="text-muted" style="font-size:12px; margin-top:2px;"><%= task.description %></div>
                <% } %>
              </td>

              <td>
                <%= task.project ? task.project.name : 'N/A' %>
              </td>

              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="member-avatar" style="width:32px;height:32px;font-size:12px;">
                    <%= task.assignedTo ? task.assignedTo.name.charAt(0).toUpperCase() : '?' %>
                  </div>
                  <%= task.assignedTo ? task.assignedTo.name : 'Unassigned' %>
                </div>
              </td>

              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="member-avatar" style="width:32px;height:32px;font-size:12px;background:var(--accent-secondary,#6366f1);">
                    <%= task.createdBy ? task.createdBy.name.charAt(0).toUpperCase() : '?' %>
                  </div>
                  <%= task.createdBy ? task.createdBy.name : 'N/A' %>
                </div>
              </td>

              <td>

                <span class="
                  badge
                  status-badge
                  <%= task.status %>
                ">

                  <%= task.status %>

                </span>

              </td>

              <td>

                <span class="
                  badge
                  priority-badge
                  <%= task.priority %>
                ">

                  <%= task.priority %>

                </span>

              </td>

              <td>

                <%= new Date(task.dueDate).toLocaleDateString() %>
                <% if (new Date(task.dueDate) < new Date() && task.status !== 'DONE') { %>
                  <span class="badge bg-danger ms-1" style="font-size:10px;">OVERDUE</span>
                <% } %>

              </td>

              <td>

                <% const canUpdate = locals.user && (locals.user.role === 'ADMIN' || (task.assignedTo && String(task.assignedTo.id) === String(locals.user.id))); %>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <a href="/tasks/<%= task.id %>" class="btn btn-sm btn-outline-primary" title="View Task Details">
                    <i class="bi bi-eye"></i>
                  </a>

                  <% if (canUpdate) { %>
                    <form
                      action="/tasks/<%= task.id %>/status"
                      method="POST"
                      class="d-flex align-items-center gap-1"
                    >
                      <select
                        name="status"
                        class="form-select form-select-sm"
                        style="min-width:120px;"
                      >
                        <option value="TODO" <%= task.status === 'TODO' ? 'selected' : '' %>>📋 TODO</option>
                        <option value="IN_PROGRESS" <%= task.status === 'IN_PROGRESS' ? 'selected' : '' %>>🔄 IN PROGRESS</option>
                        <option value="DONE" <%= task.status === 'DONE' ? 'selected' : '' %>>✅ DONE</option>
                      </select>
                      <button type="submit" class="btn btn-sm btn-primary" title="Save Status">
                        Save
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-muted" style="font-size:12px;">View Only</span>
                  <% } %>

                  <% if (locals.user && locals.user.role === 'ADMIN') { %>
                    <form
                      action="/tasks/<%= task.id %>/delete"
                      method="POST"
                      onsubmit="return confirmAction('Are you sure you want to delete this task?')"
                    >
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Task">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  <% } %>
                </div>

              </td>


            </tr>

          <% }) %>

        <% } else { %>

          <tr>

            <td colspan="8">

              <div class="empty-state py-5">

                <i class="bi bi-list-task"></i>

                <h4>
                  No Tasks Found
                </h4>

                <p>
                  <% if (locals.user && locals.user.role === 'ADMIN') { %>
                    Click "Create Task" to add your first task.
                  <% } else { %>
                    No tasks have been assigned to you yet.
                  <% } %>
                </p>

              </div>

            </td>

          </tr>

        <% } %>

      </tbody>

    </table>

  </div>

</div>

<!-- Create Task Modal (Admin Only) -->

<% if (locals.user && locals.user.role === 'ADMIN') { %>

<div
  class="modal fade"
  id="createTaskModal"
  tabindex="-1"
>

  <div class="modal-dialog modal-lg">

    <div class="modal-content modern-modal">

      <div class="modal-header">

        <h5 class="modal-title">
          Create Task
        </h5>

        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
        ></button>

      </div>

      <form
        action="/tasks/create"
        method="POST"
        id="createTaskForm"
      >

        <div class="modal-body">

          <div class="row">

            <div class="col-md-6 mb-3">

              <label class="form-label fw-semibold">
                Task Title <span class="text-danger">*</span>
              </label>

              <input
                type="text"
                name="title"
                class="form-control"
                placeholder="Enter task title"
                required
              />

            </div>

            <div class="col-md-6 mb-3">

              <label class="form-label fw-semibold">
                Project <span class="text-danger">*</span>
              </label>

              <select
                name="projectId"
                class="form-select"
                id="projectSelect"
                required
              >
                <option value="" disabled selected>-- Select a project --</option>

                <% projects.forEach(project => { %>

                  <option
                    value="<%= project.id %>"
                  >
                    <%= project.name %>
                  </option>

                <% }) %>

              </select>

            </div>

          </div>

          <div class="mb-3">

            <label class="form-label fw-semibold">
              Description
            </label>

            <textarea
              name="description"
              rows="3"
              class="form-control"
              placeholder="Optional task description..."
            ></textarea>

          </div>

          <div class="row">

            <div class="col-md-4 mb-3">

              <label class="form-label fw-semibold">
                Priority
              </label>

              <select
                name="priority"
                class="form-select"
              >

                <option value="LOW">🟦 LOW</option>
                <option value="MEDIUM" selected>🟨 MEDIUM</option>
                <option value="HIGH">🟥 HIGH</option>

              </select>

            </div>

            <div class="col-md-4 mb-3">

              <label class="form-label fw-semibold">
                Assign To <span class="text-danger">*</span>
              </label>

              <select
                name="assignedToUserId"
                class="form-select"
                id="assigneeSelect"
                required
              >
                <option value="" disabled selected>-- Select a member --</option>
                <% users.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.name %> (<%= u.email %>)</option>
                <% }) %>
              </select>

              <small class="text-muted">Users selected will be automatically added to the project if not already a member.</small>

            </div>

            <div class="col-md-4 mb-3">

              <label class="form-label fw-semibold">
                Due Date <span class="text-danger">*</span>
              </label>

              <input
                type="date"
                name="dueDate"
                class="form-control"
                required
                min="<%= new Date().toISOString().split('T')[0] %>"
              />

            </div>

          </div>

        </div>

        <div class="modal-footer">

          <button
            type="button"
            class="btn btn-outline-secondary"
            data-bs-dismiss="modal"
          >
            Cancel
          </button>

          <button
            type="submit"
            class="btn btn-primary"
            id="submitTaskBtn"
          >
            <i class="bi bi-plus-lg me-1"></i>Create Task
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

<% } %>

<script>
// Read query params and show alerts via JS (for redirect-based flash messages)
const urlParams = new URLSearchParams(window.location.search);
const pageError = urlParams.get('error');
const pageSuccess = urlParams.get('success');

if (pageError && !document.querySelector('.alert-danger')) {
  const mainContent = document.querySelector('.main-content') || document.body;
  const el = document.createElement('div');
  el.className = 'alert alert-danger alert-dismissible fade show';
  el.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>' + decodeURIComponent(pageError) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  mainContent.prepend(el);
}
if (pageSuccess && !document.querySelector('.alert-success')) {
  const mainContent = document.querySelector('.main-content') || document.body;
  const el = document.createElement('div');
  el.className = 'alert alert-success alert-dismissible fade show';
  el.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + decodeURIComponent(pageSuccess) + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
  mainContent.prepend(el);
}

});
</script>