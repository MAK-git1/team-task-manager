.border-left-priority-HIGH {
  border-left-color: #f43f5e !important; /* Rose accent */
}
.border-left-priority-MEDIUM {
  border-left-color: #f59e0b !important; /* Amber accent */
}
.border-left-priority-LOW {
  border-left-color: #0ea5e9 !important; /* Sky accent */
}

/* Glass table overrides */
.overdue-row-modern {
  background: rgba(244, 63, 94, 0.02) !important;
}
.overdue-row-modern td {
  color: #f43f5e !important;
}

/* View switcher button styles */
#viewToggleTable, #viewToggleGrid {
  background: transparent;
  color: var(--text-muted);
  border: none;
  transition: all 0.2s ease;
}
#viewToggleTable.active, #viewToggleGrid.active {
  background: var(--card-bg) !important;
  color: #6366f1 !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05) !important;
}

/* Status Filter custom behavior */
.filter-pill {
  transition: all 0.25s ease;
  border-color: var(--border-color) !important;
  color: var(--text-muted) !important;
}
.filter-pill:hover {
  background: rgba(99, 102, 241, 0.04) !important;
  color: #6366f1 !important;
  border-color: rgba(99, 102, 241, 0.2) !important;
}
.filter-pill.active {
  background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
  color: white !important;
  border-color: transparent !important;
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2) !important;
}

/* Animated transitions for filtering */
.task-table-row, .task-card-item {
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(5px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>